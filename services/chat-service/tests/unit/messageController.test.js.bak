/**
 * Unit Tests for Message Controller (Issue #12 + #16)
 * 
 * Coverage targets: 80%+ statements, branches, functions, lines
 * Mocks: Message, Room, cacheService, rabbitPublisher (controller logic tested in isolation)
 */

const messageController = require('../../src/controllers/messageController');
const Message = require('../../src/models/Message');
const Room = require('../../src/models/Room');
const { getCachedMessages, cacheMessages, invalidateCache } = require('../../src/services/cacheService');
const { publishMessageCreated } = require('../../src/publishers/rabbitPublisher');

// Mock all external dependencies
jest.mock('../../src/models/Message');
jest.mock('../../src/models/Room');
jest.mock('../../src/services/cacheService', () => ({
  getCachedMessages: jest.fn().mockResolvedValue(null),
  cacheMessages: jest.fn().mockResolvedValue(undefined),
  invalidateCache: jest.fn().mockResolvedValue(undefined),
}));
jest.mock('../../src/publishers/rabbitPublisher', () => ({
  publishMessageCreated: jest.fn().mockResolvedValue(undefined),
}));

// Standard mock request factory
const mockReq = (overrides = {}) => ({
  body: {},
  params: {},
  query: {},
  user: { userId: 'user-1' },
  ...overrides,
});

// Standard mock response factory
const mockRes = () => {
  const res = {};
  res.status = jest.fn().mockReturnValue(res);
  res.json = jest.fn().mockReturnValue(res);
  return res;
};

// Clean mocks between tests
afterEach(() => {
  jest.clearAllMocks();
});

// ============================================================================
// SEND MESSAGE TESTS (POST /rooms/:roomId/messages)
// ============================================================================
describe('sendMessage', () => {
  
  test('returns 400 when content is missing', async () => {
    Room.findById.mockResolvedValue({ _id: 'r1' });
    
    const req = mockReq({ body: {}, params: { id: 'r1' } });
    const res = mockRes();
    
    await messageController.sendMessage(req, res);
    
    expect(res.status).toHaveBeenCalledWith(400);
    expect(res.json).toHaveBeenCalledWith(
      expect.objectContaining({ error: expect.any(String) })
    );
  });

  test('returns 400 when content is empty string', async () => {
    Room.findById.mockResolvedValue({ _id: 'r1' });
    
    const req = mockReq({ body: { content: '' }, params: { id: 'r1' } });
    const res = mockRes();
    
    await messageController.sendMessage(req, res);
    
    expect(res.status).toHaveBeenCalledWith(400);
  });

  test('returns 404 when room does not exist', async () => {
    Room.findById.mockResolvedValue(null);
    
    const req = mockReq({ body: { content: 'hello' }, params: { id: 'nonexistent' } });
    const res = mockRes();
    
    await messageController.sendMessage(req, res);
    
    expect(Room.findById).toHaveBeenCalledWith('nonexistent');
    expect(res.status).toHaveBeenCalledWith(404);
  });

  test('creates message and returns 201', async () => {
    Room.findById.mockResolvedValue({ _id: 'r1' });
    
    const mockMsg = { 
      _id: 'm1', 
      content: 'hello', 
      roomId: 'r1', 
      userId: 'user-1',
      createdAt: new Date(),
      updatedAt: new Date()
    };
    Message.create.mockResolvedValue(mockMsg);
    
    const req = mockReq({ 
      body: { content: 'hello' }, 
      params: { id: 'r1' } 
    });
    const res = mockRes();
    
    await messageController.sendMessage(req, res);
    
    expect(Message.create).toHaveBeenCalledWith(
      expect.objectContaining({
        roomId: 'r1',
        userId: 'user-1',
        content: 'hello'
      })
    );
    expect(invalidateCache).toHaveBeenCalledWith('r1');
    expect(publishMessageCreated).toHaveBeenCalledWith(
      expect.objectContaining({
        roomId: 'r1',
        userId: 'user-1',
        messageId: 'm1',
        timestamp: expect.any(String)
      })
    );
    expect(res.status).toHaveBeenCalledWith(201);
    expect(res.json).toHaveBeenCalledWith(mockMsg);
  });

  test('handles database error gracefully', async () => {
    Room.findById.mockResolvedValue({ _id: 'r1' });
    Message.create.mockRejectedValue(new Error('Database connection failed'));
    
    const req = mockReq({ body: { content: 'hello' }, params: { id: 'r1' } });
    const res = mockRes();
    
    await messageController.sendMessage(req, res);
    
    expect(res.status).toHaveBeenCalledWith(500);
  });
});

// ============================================================================
// GET MESSAGES TESTS (GET /rooms/:roomId/messages) - CRITICAL FOR PAGINATION
// ============================================================================
describe('getMessages', () => {
  
  // --- Cache Layer Tests ---
  
  test('returns cached messages on cache HIT', async () => {
    const cachedMessages = [
      { _id: 'm1', content: 'cached 1', createdAt: new Date() },
      { _id: 'm2', content: 'cached 2', createdAt: new Date() }
    ];
    getCachedMessages.mockResolvedValue(cachedMessages);
    
    const req = mockReq({ params: { roomId: 'r1' }, query: { limit: '10' } });
    const res = mockRes();
    
    await messageController.getMessages(req, res);
    
    expect(getCachedMessages).toHaveBeenCalledWith('r1');
    // Should NOT query MongoDB when cache HIT
    expect(Message.find).not.toHaveBeenCalled();
    expect(res.json).toHaveBeenCalledWith(
      expect.objectContaining({
        messages: cachedMessages,
        nextCursor: expect.anything(),
        source: 'cache'
      })
    );
  });

  test('queries MongoDB on cache MISS and caches result', async () => {
    getCachedMessages.mockResolvedValue(null); // Cache MISS
    
    const mockMessages = [
      { _id: 'm1', content: 'db 1', roomId: 'r1', userId: 'u1', createdAt: new Date() }
    ];
    
    // Mock chainable Mongoose query
    Message.find = jest.fn().mockReturnValue({
      sort: jest.fn().mockReturnValue({
        limit: jest.fn().mockResolvedValue(mockMessages)
      })
    });
    
    const req = mockReq({ params: { roomId: 'r1' }, query: { limit: '10' } });
    const res = mockRes();
    
    await messageController.getMessages(req, res);
    
    expect(getCachedMessages).toHaveBeenCalledWith('r1');
    expect(Message.find).toHaveBeenCalledWith({ roomId: 'r1' });
    expect(cacheMessages).toHaveBeenCalledWith('r1', expect.any(Array));
    expect(res.json).toHaveBeenCalledWith(
      expect.objectContaining({
        messages: mockMessages,
        source: 'db'
      })
    );
  });

  // --- Pagination Cursor Logic Tests (EXPLICITLY REQUIRED FOR ISSUE #16) ---
  
  test('returns nextCursor when more messages exist (limit+1 fetch)', async () => {
    getCachedMessages.mockResolvedValue(null);
    
    // Fetch 11 messages when limit=10 to detect if more exist
    const messages = Array(11).fill(null).map((_, i) => ({
      _id: `msg-${String(i).padStart(2, '0')}`,
      content: `Message ${i}`,
      roomId: 'r1',
      userId: 'user-1',
      createdAt: new Date(Date.now() - i * 1000)
    }));
    
    Message.find = jest.fn().mockReturnValue({
      sort: jest.fn().mockReturnValue({
        limit: jest.fn().mockResolvedValue(messages)
      })
    });
    
    const req = mockReq({ 
      params: { roomId: 'r1' }, 
      query: { limit: '10' } 
    });
    const res = mockRes();
    
    await messageController.getMessages(req, res);
    
    // Verify we fetched limit+1
    expect(Message.find().sort().limit).toHaveBeenCalledWith(11);
    
    // Verify response includes nextCursor (ID of 11th message)
    expect(res.json).toHaveBeenCalledWith(
      expect.objectContaining({
        messages: expect.arrayContaining([expect.any(Object)]),
        nextCursor: 'msg-10' // ID of the extra message fetched
      })
    );
  });

  test('returns null nextCursor when no more messages', async () => {
    getCachedMessages.mockResolvedValue(null);
    
    // Fetch exactly 10 messages when limit=10 = no more pages
    const messages = Array(10).fill(null).map((_, i) => ({
      _id: `msg-${i}`,
      content: `Message ${i}`,
      roomId: 'r1',
      userId: 'user-1',
      createdAt: new Date()
    }));
    
    Message.find = jest.fn().mockReturnValue({
      sort: jest.fn().mockReturnValue({
        limit: jest.fn().mockResolvedValue(messages)
      })
    });
    
    const req = mockReq({ 
      params: { roomId: 'r1' }, 
      query: { limit: '10' } 
    });
    const res = mockRes();
    
    await messageController.getMessages(req, res);
    
    // Verify we still fetched limit+1 to check
    expect(Message.find().sort().limit).toHaveBeenCalledWith(11);
    
    // Verify nextCursor is null (no more pages)
    expect(res.json).toHaveBeenCalledWith(
      expect.objectContaining({
        nextCursor: null
      })
    );
  });

  test('uses cursor with $lt operator when provided', async () => {
    getCachedMessages.mockResolvedValue(null);
    
    Message.find = jest.fn().mockReturnValue({
      sort: jest.fn().mockReturnValue({
        limit: jest.fn().mockResolvedValue([])
      })
    });
    
    const req = mockReq({ 
      params: { roomId: 'r1' }, 
      query: { limit: '10', cursor: 'msg-05' } 
    });
    const res = mockRes();
    
    await messageController.getMessages(req, res);
    
    // Verify query includes cursor filter with $lt
    expect(Message.find).toHaveBeenCalledWith(
      expect.objectContaining({
        roomId: 'r1',
        _id: { $lt: 'msg-05' }
      })
    );
  });

  test('handles invalid cursor format gracefully', async () => {
    getCachedMessages.mockResolvedValue(null);
    
    // Mongoose may throw CastError for invalid ObjectId cursor
    Message.find = jest.fn().mockImplementation(() => {
      throw new Error('Cast to ObjectId failed');
    });
    
    const req = mockReq({ 
      params: { roomId: 'r1' }, 
      query: { limit: '10', cursor: 'invalid-cursor-format' } 
    });
    const res = mockRes();
    
    await messageController.getMessages(req, res);
    
    // Should return 400 for invalid cursor
    expect(res.status).toHaveBeenCalledWith(400);
  });

  test('handles database error gracefully', async () => {
    getCachedMessages.mockResolvedValue(null);
    
    Message.find = jest.fn().mockReturnValue({
      sort: jest.fn().mockReturnValue({
        limit: jest.fn().mockRejectedValue(new Error('Query failed'))
      })
    });
    
    const req = mockReq({ params: { roomId: 'r1' }, query: { limit: '10' } });
    const res = mockRes();
    
    await messageController.getMessages(req, res);
    
    expect(res.status).toHaveBeenCalledWith(500);
  });
});

// ============================================================================
// EDIT MESSAGE TESTS (PUT /messages/:messageId)
// ============================================================================
describe('editMessage', () => {
  
  test('returns 403 when user does not own message', async () => {
    Message.findById.mockResolvedValue({ 
      _id: 'm1', 
      userId: 'other-user', 
      save: jest.fn() 
    });
    
    const req = mockReq({ 
      params: { id: 'm1' }, 
      body: { content: 'edited' } 
    });
    const res = mockRes();
    
    await messageController.editMessage(req, res);
    
    expect(res.status).toHaveBeenCalledWith(403);
    expect(res.json).toHaveBeenCalledWith(
      expect.objectContaining({ error: 'Not authorized' })
    );
  });

  test('returns 404 when message not found', async () => {
    Message.findById.mockResolvedValue(null);
    
    const req = mockReq({ 
      params: { id: 'nonexistent' }, 
      body: { content: 'edited' } 
    });
    const res = mockRes();
    
    await messageController.editMessage(req, res);
    
    expect(res.status).toHaveBeenCalledWith(404);
  });

  test('edits message when user is owner', async () => {
    const save = jest.fn().mockResolvedValue({
      _id: 'm1',
      userId: 'user-1',
      content: 'new content',
      editedAt: new Date(),
      roomId: 'r1'
    });
    
    Message.findById.mockResolvedValue({
      _id: 'm1',
      userId: 'user-1',
      content: 'old',
      editedAt: null,
      save,
      roomId: 'r1'
    });
    
    const req = mockReq({ 
      params: { id: 'm1' }, 
      body: { content: 'new content' } 
    });
    const res = mockRes();
    
    await messageController.editMessage(req, res);
    
    expect(save).toHaveBeenCalled();
    expect(invalidateCache).toHaveBeenCalledWith('r1');
    expect(res.json).toHaveBeenCalledWith(
      expect.objectContaining({
        _id: 'm1',
        content: 'new content',
        editedAt: expect.any(Date)
      })
    );
  });

  test('returns 400 when content is empty', async () => {
    Message.findById.mockResolvedValue({
      _id: 'm1',
      userId: 'user-1',
      save: jest.fn()
    });
    
    const req = mockReq({ 
      params: { id: 'm1' }, 
      body: { content: '' } 
    });
    const res = mockRes();
    
    await messageController.editMessage(req, res);
    
    expect(res.status).toHaveBeenCalledWith(400);
  });

  test('handles database error gracefully', async () => {
    Message.findById.mockRejectedValue(new Error('Database error'));
    
    const req = mockReq({ 
      params: { id: 'm1' }, 
      body: { content: 'edited' } 
    });
    const res = mockRes();
    
    await messageController.editMessage(req, res);
    
    expect(res.status).toHaveBeenCalledWith(500);
  });
});

// ============================================================================
// DELETE MESSAGE TESTS (DELETE /messages/:messageId)
// ============================================================================
describe('deleteMessage', () => {
  
  test('returns 403 for non-owner', async () => {
    Message.findById.mockResolvedValue({ 
      _id: 'm1', 
      userId: 'other', 
      deleteOne: jest.fn() 
    });
    
    const req = mockReq({ params: { id: 'm1' } });
    const res = mockRes();
    
    await messageController.deleteMessage(req, res);
    
    expect(res.status).toHaveBeenCalledWith(403);
  });

  test('returns 404 when message not found', async () => {
    Message.findById.mockResolvedValue(null);
    
    const req = mockReq({ params: { id: 'nonexistent' } });
    const res = mockRes();
    
    await messageController.deleteMessage(req, res);
    
    expect(res.status).toHaveBeenCalledWith(404);
  });

  test('deletes message when user is owner', async () => {
    const deleteOne = jest.fn().mockResolvedValue({ deletedCount: 1 });
    
    Message.findById.mockResolvedValue({
      _id: 'm1',
      userId: 'user-1',
      roomId: 'r1',
      deleteOne
    });
    
    const req = mockReq({ params: { id: 'm1' } });
    const res = mockRes();
    
    await messageController.deleteMessage(req, res);
    
    expect(deleteOne).toHaveBeenCalled();
    expect(invalidateCache).toHaveBeenCalledWith('r1');
    expect(res.json).toHaveBeenCalledWith(
      expect.objectContaining({ message: expect.stringContaining('Deleted') })
    );
  });

  test('handles deletion failure gracefully', async () => {
    Message.findById.mockResolvedValue({
      _id: 'm1',
      userId: 'user-1',
      roomId: 'r1',
      deleteOne: jest.fn().mockRejectedValue(new Error('Delete failed'))
    });
    
    const req = mockReq({ params: { id: 'm1' } });
    const res = mockRes();
    
    await messageController.deleteMessage(req, res);
    
    expect(res.status).toHaveBeenCalledWith(500);
  });
});

// ============================================================================
// EDGE CASES & INTEGRATION
// ============================================================================
describe('Message Controller - Edge Cases', () => {
  
  test('sendMessage handles very long content (validation)', async () => {
    Room.findById.mockResolvedValue({ _id: 'r1' });
    
    const veryLongContent = 'A'.repeat(6000); // Exceeds 5000 char limit
    const req = mockReq({ 
      body: { content: veryLongContent }, 
      params: { id: 'r1' } 
    });
    const res = mockRes();
    
    await messageController.sendMessage(req, res);
    
    // Should return 400 if validation exists, or 201 if not enforced at controller
    expect([201, 400]).toContain(res.status.mock.calls[0][0]);
  });

  test('getMessages handles empty room (no messages)', async () => {
    getCachedMessages.mockResolvedValue(null);
    
    Message.find = jest.fn().mockReturnValue({
      sort: jest.fn().mockReturnValue({
        limit: jest.fn().mockResolvedValue([])
      })
    });
    
    const req = mockReq({ params: { roomId: 'empty-room' }, query: { limit: '10' } });
    const res = mockRes();
    
    await messageController.getMessages(req, res);
    
    expect(res.json).toHaveBeenCalledWith(
      expect.objectContaining({
        messages: [],
        nextCursor: null
      })
    );
  });

  test('all endpoints handle missing user in request', async () => {
    const reqWithoutUser = { body: {}, params: {}, query: {} };
    const res = mockRes();
    
    // Test sendMessage with missing user
    Room.findById.mockResolvedValue({ _id: 'r1' });
    await messageController.sendMessage({ ...reqWithoutUser, params: { id: 'r1' }, body: { content: 'test' } }, res);
    // Should return 401/403 if auth middleware not applied, or proceed if mocked
    expect([201, 400, 401, 403]).toContain(res.status.mock.calls[0][0]);
  });

  test('cache service errors do not crash getMessages', async () => {
    getCachedMessages.mockRejectedValue(new Error('Redis connection failed'));
    
    // Should gracefully fall back to MongoDB
    const mockMessages = [{ _id: 'm1', content: 'fallback', roomId: 'r1', userId: 'u1', createdAt: new Date() }];
    Message.find = jest.fn().mockReturnValue({
      sort: jest.fn().mockReturnValue({
        limit: jest.fn().mockResolvedValue(mockMessages)
      })
    });
    
    const req = mockReq({ params: { roomId: 'r1' }, query: { limit: '10' } });
    const res = mockRes();
    
    await messageController.getMessages(req, res);
    
    // Should still return data from MongoDB
    expect(res.json).toHaveBeenCalledWith(
      expect.objectContaining({ messages: mockMessages })
    );
  });
});