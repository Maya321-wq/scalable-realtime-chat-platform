{
    "name":  "chat-service",
    "version":  "1.0.0",
    "scripts":  {
                    "start":  "node src/app.js",
                    "dev":  "nodemon src/app.js",
                    "lint":  "eslint src/",
                    "test":  "jest --runInBand --passWithNoTests"
                },
    "jest":  {
                 "testEnvironment":  "node",
                 "testMatch":  [
                                   "**/*.test.js"
                               ],
                 "coverageThreshold":  {
                                           "global":  {
                                                          "lines":  80
                                                      }
                                       },
                 "rootDir":  "./",
                 "collectCoverageFrom":  [
                                             "src/**/*.js"
                                         ]
             },
    "devDependencies":  {
                            "eslint":  "^8.57.0",
                            "jest":  "^29.7.0",
                            "nodemon":  "^3.1.0"
                        },
    "dependencies":  {
                         "amqplib":  "^1.0.3",
                         "express":  "^5.2.1",
                         "ioredis":  "^5.10.1",
                         "jsonwebtoken":  "^9.0.3",
                         "mongoose":  "^9.5.0",
                         "socket.io":  "^4.8.3"
                     }
}
