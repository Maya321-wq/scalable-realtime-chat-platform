{
  "name": "chat-service",
  "version": "1.0.0",
  "scripts": {
    "start": "node src/app.js",
    "dev": "nodemon src/app.js",
    "test": "jest --runInBand --forceExit",
    "lint": "eslint src/"
  },
"jest": {
  "testEnvironment": "node",
  "collectCoverageFrom": [
    "src/**/*.js",
    "!src/app.js",
    "!src/socket/**",
    "!src/repositories/**",
    "!src/**/index.js"
  ],
  "coverageThreshold": {
    "global": {
      "branches": 50,
      "functions": 50,
      "lines": 60,
      "statements": 60
    }
  }
},
  "devDependencies": {
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.0"
  },
  "dependencies": {
    "@socket.io/redis-adapter": "^8.3.0",
    "amqplib": "^1.0.3",
    "express": "^5.2.1",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.5.0",
    "socket.io": "^4.8.3"
  }
}